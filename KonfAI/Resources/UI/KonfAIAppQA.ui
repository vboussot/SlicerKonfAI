   <connections>
      <connection>
         <sender>KonfAIAppQAWidget</sender>
         <signal>mrmlSceneChanged(vtkMRMLScene*)</signal>
         <receiver>inputVolumeEvaluationSelector</receiver>
         <slot>setMRMLScene(vtkMRMLScene*)</slot>
      </connection>
      <connection>
         <sender>KonfAIAppQAWidget</sender>
         <signal>mrmlSceneChanged(vtkMRMLScene*)</signal>
