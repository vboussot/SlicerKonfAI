                           <property name="text">
                              <string>Reference volume</string>
                           </property>
                        </widget>
                     </item>
                     <item row="2" column="1">
                        <widget class="qMRMLNodeComboBox" name="referenceVolumeSelector">
                           <property name="nodeTypes">
                              <stringlist>
                                 <string>vtkMRMLScalarVolumeNode</string>
                                 <string>vtkMRMLLabelMapVolumeNode</string>
                              </stringlist>
